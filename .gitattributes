# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto eol=lf

# Source files — always LF
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.env*      text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf

# Windows scripts — CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — no line-ending normalization
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary

# Lock files — prevent diff noise
package-lock.json   -diff
yarn.lock           -diff
pnpm-lock.yaml      -diff
