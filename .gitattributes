# Normalize line endings to LF on commit
* text=auto eol=lf

*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.env*      text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf
*.graphql   text eol=lf
*.gql       text eol=lf
*.prisma    text eol=lf

*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.avif      binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.7z        binary
*.mp4       binary
*.webm      binary
*.mp3       binary
*.wasm      binary

package-lock.json    -diff linguist-generated=true merge=ours
yarn.lock            -diff linguist-generated=true merge=ours
pnpm-lock.yaml       -diff linguist-generated=true merge=ours

next-env.d.ts                 linguist-generated=true
src/db/migrations/*.sql       linguist-generated=true
src/db/migrations/meta/*.json linguist-generated=true
*.tsbuildinfo                 linguist-generated=true

*.ts        linguist-language=TypeScript
*.tsx       linguist-language=TypeScript

.github/            export-ignore
.gitattributes      export-ignore
.gitignore          export-ignore
.env.example        export-ignore
jest.config.ts      export-ignore
drizzle.config.ts   export-ignore
scripts/            export-ignore
