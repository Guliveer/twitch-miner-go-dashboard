# Supabase API credentials (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_[your-key]

# Supabase secret key (server-only, never exposed to client)
# Found in Supabase Dashboard → Settings → API → secret key
SUPABASE_SECRET_KEY=

# Bot API — address of the twitch-miner-go analytics server (default port 8080)
# Used to check device code auth status for bot accounts.
# Examples: http://192.168.1.50:8080, https://bot.example.com
# BOT_URL=
#
# API key for the bot's analytics server (machine-to-machine auth).
# Must match DASHBOARD_API_KEY in the bot's .env.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BOT_API_KEY=
