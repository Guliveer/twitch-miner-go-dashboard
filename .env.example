# Neon PostgreSQL connection string (from Neon console → Connection details)
DB_DSN=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Neon Auth base URL (from Neon console → Auth → Settings → Base URL)
# Format: https://<endpoint>.neonauth.<region>.aws.neon.tech/<dbname>/auth
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth

# Random 32-byte hex secret for signing auth session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEON_AUTH_COOKIE_SECRET=your_64_char_hex_secret_here

# Bot API — address of the twitch-miner-go analytics server (default port 8080)
# Used to check device code auth status for bot accounts.
# Examples: http://192.168.1.50:8080, https://bot.example.com
# BOT_URL=
#
# API key for the bot's analytics server (machine-to-machine auth).
# Must match DASHBOARD_API_KEY in the bot's .env.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BOT_API_KEY=
